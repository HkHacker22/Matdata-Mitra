# ============================================
# Matdata Mitra - Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ---------- Firebase (Client SDK) ----------
# Get these from: Firebase Console > Project Settings > Your Apps > Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ---------- Backend API ----------
VITE_API_BASE_URL=http://localhost:3001/api

# ---------- Server-side (used by server/) ----------
# MongoDB Atlas: Atlas Dashboard > Connect > Drivers > Copy URI
MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/matdata_mitra?retryWrites=true&w=majority

# JWT secret for signing tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=3001

# ---------- Firebase Admin (Server-side) ----------
# Download service account JSON from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Place file as server/config/serviceAccountKey.json (already gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# ---------- Google Maps (Optional) ----------
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key
